{
  "name": "api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "node --test --import tsx src/lib/api-response.test.ts src/modules/knowledge/knowledge.shared.test.ts src/modules/knowledge/knowledge.service.test.ts src/modules/projects/projects.service.test.ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "jose": "^6.2.1",
    "mongodb": "^7.1.0",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.10.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "5.9.2"
  }
}
