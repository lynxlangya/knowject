COMPOSE_PROJECT_NAME=knowject
MONGO_IMAGE_TAG=8.2.5
CHROMA_IMAGE_TAG=1.5.5
PUBLIC_DOMAIN=knowject.example.com
PUBLIC_HTTP_PORT=80
PUBLIC_HTTPS_PORT=443
NODE_ENV=production
APP_NAME=knowject-api
LOG_LEVEL=info
CORS_ORIGIN=https://knowject.example.com
MONGO_INITDB_ROOT_USERNAME=knowject_root
MONGO_APP_DATABASE=knowject
MONGO_APP_USERNAME=knowject_app
MONGO_AUTH_SOURCE=knowject
MONGODB_DB_NAME=knowject
JWT_EXPIRES_IN=12h
JWT_ISSUER=knowject-api
JWT_AUDIENCE=knowject-platform
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=1
API_ERROR_EXPOSE_DETAILS=false
API_ERROR_INCLUDE_STACK=false
CHROMA_URL=http://chroma:8000
CHROMA_HEARTBEAT_PATH=/api/v2/heartbeat
CHROMA_ALLOW_RESET=FALSE
CHROMA_ANONYMIZED_TELEMETRY=FALSE
KNOWLEDGE_STORAGE_ROOT=/var/lib/knowject/knowledge
KNOWLEDGE_INDEXER_URL=http://indexer-py:8001
KNOWLEDGE_INDEXER_TIMEOUT_MS=15000
KNOWLEDGE_INDEXER_PORT=8001
