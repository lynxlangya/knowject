{
  "name": "knowject",
  "private": true,
  "author": {
    "name": "Mr.langya"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter platform dev",
    "dev:api": "pnpm --filter api dev",
    "dev:init": "bash ./scripts/knowject.sh dev:init",
    "dev:up": "bash ./scripts/knowject.sh dev:up",
    "dev:deps:up": "bash ./scripts/knowject.sh dev:deps:up",
    "dev:deps:down": "bash ./scripts/knowject.sh dev:deps:down",
    "dev:deps:ps": "bash ./scripts/knowject.sh dev:deps:ps",
    "dev:deps:logs": "bash ./scripts/knowject.sh dev:deps:logs",
    "dev:deps:health": "bash ./scripts/knowject.sh dev:deps:health",
    "dev:check": "bash ./scripts/knowject.sh dev:check",
    "dev:build": "bash ./scripts/knowject.sh dev:build",
    "host:init": "bash ./scripts/knowject.sh host:init",
    "host:up": "bash ./scripts/knowject.sh host:up",
    "host:web": "bash ./scripts/knowject.sh host:web",
    "host:api": "bash ./scripts/knowject.sh host:api",
    "host:check": "bash ./scripts/knowject.sh host:check",
    "host:build": "bash ./scripts/knowject.sh host:build",
    "docker:local:init": "bash ./scripts/knowject.sh docker:local:init",
    "docker:local:up": "bash ./scripts/knowject.sh docker:local:up",
    "docker:local:down": "bash ./scripts/knowject.sh docker:local:down",
    "docker:local:ps": "bash ./scripts/knowject.sh docker:local:ps",
    "docker:local:logs": "bash ./scripts/knowject.sh docker:local:logs",
    "docker:local:config": "bash ./scripts/knowject.sh docker:local:config",
    "docker:local:health": "bash ./scripts/knowject.sh docker:local:health",
    "docker:local:reset": "bash ./scripts/knowject.sh docker:local:reset",
    "docker:prod:init": "bash ./scripts/knowject.sh docker:prod:init",
    "docker:prod:up": "bash ./scripts/knowject.sh docker:prod:up",
    "docker:prod:down": "bash ./scripts/knowject.sh docker:prod:down",
    "docker:prod:ps": "bash ./scripts/knowject.sh docker:prod:ps",
    "docker:prod:logs": "bash ./scripts/knowject.sh docker:prod:logs",
    "docker:prod:config": "bash ./scripts/knowject.sh docker:prod:config",
    "knowject:help": "bash ./scripts/knowject.sh help",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "pnpm test:api && pnpm test:indexer",
    "test:api": "pnpm --filter api test",
    "test:indexer": "pnpm --filter indexer-py test",
    "check-types": "turbo run check-types",
    "typecheck": "turbo run check-types"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.7.3",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.52.0"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22"
  }
}
