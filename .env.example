# Knowject foundation-phase environment contract
# Copy this file to `.env.local` before local development.
# Runtime loads `.env` first, then `.env.local`; `.env.local` can override lower-priority values.
# Canonical `*_FILE` contract is reserved for secrets / connection strings:
# `MONGODB_URI(_FILE)`, `JWT_SECRET(_FILE)`, `SETTINGS_ENCRYPTION_KEY(_FILE)`,
# optional `KNOWLEDGE_INDEXER_INTERNAL_TOKEN(_FILE)` / `OPENAI_API_KEY(_FILE)`.
# Do not define both `NAME` and `NAME_FILE` in the same env file.
# Replace every CHANGE_ME placeholder with a real secret or password.
# Generate JWT_SECRET with: `openssl rand -base64 48`

# App
NODE_ENV=development
APP_NAME=knowject-api
PORT=3001
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:5173

# MongoDB
# 本地推荐工作流下，`pnpm dev:init` / `pnpm dev:up` 会把这里同步为 `MONGODB_URI_FILE=...`
# 宿主机开发统一以 `MONGODB_URI` / `MONGODB_URI_FILE` 为 canonical；不要在 `.env.local` 中继续新增 `MONGO_*` 兼容键。
MONGODB_URI=mongodb://knowject_app:CHANGE_ME_APP_PASSWORD@127.0.0.1:27017/knowject?authSource=knowject
MONGODB_DB_NAME=knowject

# Chroma (optional)
# CHROMA_URL=http://127.0.0.1:8000
CHROMA_HEARTBEAT_PATH=/api/v2/heartbeat
# CHROMA_TENANT=default_tenant
# CHROMA_DATABASE=default_database
# CHROMA_TIMEOUT_MS=15000

# Knowledge storage (optional)
# Defaults to <workspace>/.knowject-storage/knowledge when omitted.
# KNOWLEDGE_STORAGE_ROOT=/absolute/path/to/knowledge-storage
# KNOWLEDGE_INDEXER_URL=http://127.0.0.1:8001
# KNOWLEDGE_INDEXER_TIMEOUT_MS=15000
# 若 indexer 在非 development 且启用 internal bearer 校验，可通过 *_FILE 注入共享 token。
# KNOWLEDGE_INDEXER_INTERNAL_TOKEN_FILE=/absolute/path/to/knowledge_indexer_internal_token.txt

# Skill storage (optional)
# Defaults to <workspace>/.knowject-storage/skills when omitted.
# SKILLS_STORAGE_ROOT=/absolute/path/to/skills-storage

# OpenAI embeddings (required for GA-06 indexing/retrieval)
# OPENAI_API_KEY=sk-...
# OPENAI_API_KEY_FILE=/absolute/path/to/openai_api_key.txt
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_TIMEOUT_MS=15000

# Settings encryption (required)
# 本地推荐工作流下，`pnpm dev:init` / `pnpm dev:up` / `pnpm host:init` 会把这里同步为 `SETTINGS_ENCRYPTION_KEY_FILE=...`
# Generate with: openssl rand -hex 32
SETTINGS_ENCRYPTION_KEY=

# JWT
# 本地推荐工作流下，`pnpm dev:init` / `pnpm dev:up` 会把这里同步为 `JWT_SECRET_FILE=...`
JWT_SECRET=CHANGE_ME_WITH_OPENSSL_BASE64_48
JWT_EXPIRES_IN=12h
JWT_ISSUER=knowject-api
JWT_AUDIENCE=knowject-platform

# Password hashing (argon2id)
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=1

# Error response behavior
API_ERROR_EXPOSE_DETAILS=false
API_ERROR_INCLUDE_STACK=false
